#!/usr/bin/env bash
# =============================================================================
# pre-push hook: 防止 force push 误操作 + 给 main 直推一个软警告
# =============================================================================
# 设计: 单人开发, 不强制走 PR。main 直推允许, 但打一个 yellow 警告让你知道
# 自己在干嘛。force push 全部禁止, 删 main 也禁止 (防误操作)。
# =============================================================================

set -euo pipefail

# 读取 git 喂给 hook 的 stdin
# 格式: <local_ref> <local_oid> <remote_ref> <remote_oid> (每行一组)
while read -r local_ref local_oid remote_ref remote_oid; do
  [ -z "$local_ref" ] && continue

  remote_branch="${remote_ref#refs/heads/}"

  case "$remote_branch" in
    main|master)
      # 单人开发, 不拦直推, 只警告一下
      echo "[pre-push] ⚠️  正在直推 ${remote_branch} (单人开发允许, 但确认你 push 的是对的)"
      ;;
  esac
done

exit 0
